      "auth": {
        "controllers": [
          "POST /auth/login",
          "POST /auth/refresh",
          "POST /auth/logout",
          "GET /auth/me"
        ],
        "implementationNotes": [
          "Login normalizes email to lowercase.",
          "Password verification uses Argon2.",
          "Refresh token is JWT signed with refresh secret and stored as Argon2 hash.",
          "Refresh flow revokes old matching refresh token and creates a new session."
        ]
      },
      "users": {
        "controllers": [
          "GET /users",
          "GET /users/:id",
          "POST /users",
          "PATCH /users/:id",
          "DELETE /users/:id"
        ],
        "rolePolicy": {
          "read": [
            "super_admin",
            "admin"
          ],
          "write": [
            "super_admin"
          ]
        },
        "publicUserExcludes": [
          "passwordHash"
        ]
      },
      "settings": {
        "controllers": [
          "GET /settings/app",
          "PATCH /settings/app"
        ],
        "rolePolicy": {
          "read": "JWT authenticated users",
          "write": [
            "super_admin",
            "admin"
          ]
        },
        "storage": "Single AppSettings row with id global"
      },
      "records": {
        "controllers": [
          "GET /records/:type",
          "POST /records/:type",
          "POST /records/:type/bulk",
          "PATCH /records/:id",
          "DELETE /records/:id"
        ],
        "storage": "LifeosRecord JSON payload table",
        "accessPolicy": [
          "viewer cannot write",
          "member can access own records",
          "admin and super_admin can access broader records",
          "bulkReplace normalizes invalid legacy userId to logged-in user id"
        ],
        "softDeleteField": "deletedAt"
      },
      "uploads": {
        "controllers": [
          "POST /uploads",
          "GET /uploads",
          "GET /uploads/:id",
          "GET /uploads/:id/metadata",
          "DELETE /uploads/:id"
        ],
        "maxUploadBytes": 104857600,
        "storageFlow": [
          "Multer memoryStorage receives file",
          "SHA-256 checksum calculated",
          "File is saved to S3-compatible object storage",
          "Asset row and AssetExtraction row are created",
          "Extraction job is enqueued"
        ],
        "objectKeyPattern": "<userId>/<yyyy>/<mm>/<timestamp>-<uuid><extension>"
      },
      "storage": {
        "provider": "S3Client",
        "bucketEnv": "ASSET_BUCKET",
        "startupBehavior": "ensureBucket via HeadBucket then CreateBucket"
      },
      "extraction": {
        "queueName": "asset-extraction",
        "workerConcurrencyEnv": "EXTRACTION_CONCURRENCY",
        "supportedMimeTypes": [
          "text/*",
          "application/json",
          "application/xml",
          "application/yaml"
        ],
        "resultFields": [
          "extractedText",
          "summary",
          "metadata.extractedCharacters",
          "completedAt"
        ],
        "unsupportedBehavior": "AssetExtraction.status becomes unsupported and Asset.status becomes ready."
      }
    }
  },
