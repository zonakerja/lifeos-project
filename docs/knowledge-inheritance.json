  "knownLimitations": [
    {
      "area": "Frontend structure",
      "description": "Several feature files remain very large after initial refactor, especially FileControlManager and ProductivityManager."
    },
    {
      "area": "Persistence",
      "description": "Most domain data is stored as JSON payload in LifeosRecord. This is flexible but weak for typed constraints, relational querying, and reporting."
    },
    {
      "area": "Uploads",
      "description": "Backend uses Multer memoryStorage with 100 MB limit. Large-scale document ingestion should move to streaming or presigned upload."
    },
    {
      "area": "Extraction",
      "description": "Only text-like MIME types are extracted. PDF, DOCX, XLSX, image OCR, and embedding/indexing are pending."
    },
    {
      "area": "Auth",
      "description": "Refresh token validation scans active token records and Argon2-verifies each candidate. Add token identifiers for scale."
    },
    {
      "area": "AI",
      "description": "Gemini requests are made from the frontend with user API key. Backend AI proxying is safer for production."
    },
    {
      "area": "Testing",
      "description": "No automated backend or frontend test suite exists yet beyond lint/build/manual smoke checks."
    },
    {
      "area": "Encoding",
      "description": "Some UI strings contain mojibake such as Â© and bullet placeholders."
    }
  ],
